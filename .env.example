# API Keys for Challenge Generation
# Copy this file to .env and fill in your API keys

# Anthropic API (required)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Currents API (optional but recommended)
# Get from: https://currentsapi.services/
CURRENTS_API_KEY=your_currents_api_key_here

# OMDb API (optional)
# Get from: http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# RAWG API (optional)
# Get from: https://rawg.io/apidocs
RAWG_API_KEY=your_rawg_api_key_here

# NYT Books API (optional)
# Get from: https://developer.nytimes.com/
NYT_API_KEY=your_nyt_api_key_here
